{
  "editor.codeActionsOnSave": {
    "source.fixAll.oxlint": "explicit",
    "source.organizeImports": "explicit",
    "source.fixAll.stylelint": "explicit"
  },

  "editor.defaultFormatter": "oxc.oxc-vscode",

  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },

  "editor.formatOnSave": true
}
