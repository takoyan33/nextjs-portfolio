          <mxGeometry x="35" y="540" width="430" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="pc-6" value="No6: History&#xa;経歴タイムライン / About CTA" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="screen">
          <mxGeometry x="35" y="720" width="430" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="pc-7" value="No7: Skill&#xa;Frontend / Backend / Infra / Other の3カラムカード" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f7fb;" vertex="1" parent="screen">
          <mxGeometry x="35" y="870" width="430" height="150" as="geometry"/>
