#!/usr/bin/env sh

echo "----- start pre-commit -------"

# ステージされたファイル一覧
STAGED_FILES=$(git diff --cached --name-only)

# 次のいずれか「だけ」の変更なら format / lint / build / test をスキップ:
# - *.md
# - .agents/ .codex/ .cursor/ .gemini/ .husky/ .github/ docs/ public/ .vscode/ perf/ mocks/ 配下
# grep . は一致なしで exit 1 のため || true（set -e 対策）
NON_TARGET_FILES=$(printf '%s\n' "$STAGED_FILES" \
  | grep -vE '\.md$|^\.agents/|^\.codex/|^\.cursor/|^\.gemini/|^\.husky/|^\.github/|^\.docs/|^\public/|^\.vscode/|^\perf/|^\mocks/' \
  | grep . || true)

if [ -z "$NON_TARGET_FILES" ]; then
  echo "Only *.md or under .agents / .codex / .cursor / .gemini / .husky / .github / .docs / public / .vscode perf/ mocks/ Skipping format, lint, typecheck, build, and tests."
  echo "----- end pre-commit (skipped) -------"
  exit 0
fi


# コードフォーマット
yarn format

# リンター（OxLint）
yarn lint

# スタイルリンター（Stylelint）
yarn lint:stylelint

# フォーマットチェック
yarn format:check

# 型チェック
yarn typecheck

# ビルド（型チェックも含む）
yarn build

# Storybookビルド
yarn build-storybook

# テスト（Node環境）
yarn test --project node

echo "----- end pre-commit -------"