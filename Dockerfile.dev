# Node.js 公式イメージをベースに使用
FROM node:20-alpine

# アプリケーション用ディレクトリを作成
WORKDIR /usr/src/app

# package ファイルのみ先にコピー
COPY package.json pnpm-lock.yaml ./

# pnpm を有効化して依存関係をインストール
RUN corepack enable && pnpm install --frozen-lockfile

# ソースコードをコピー（node_modules は .dockerignore 推奨）
COPY . .

# 使用ポートを公開
EXPOSE 3001

# 開発サーバーを起動
CMD ["pnpm", "dev:mock"]